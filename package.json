{
  "name": "agentbridge",
  "version": "0.1.0",
  "private": true,
  "description": "AgentBridge — The secure browser workspace for AI agents",
  "workspaces": [
    "packages/core",
    "packages/companion",
    "packages/extension",
    "packages/sdk",
    "packages/cli"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "dev:companion": "npm run dev -w @agentbridge/companion",
    "dev:extension": "npm run dev -w @agentbridge/extension"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.3.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "MIT"
}
